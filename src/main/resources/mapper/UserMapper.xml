<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.strayanimalrescuebackend.mapper.UserMapper">

    <!-- 查询用户名或邮箱是否已存在 -->
    <select id="checkUserExists" resultType="int">
        SELECT COUNT(*) FROM user WHERE username = #{username} OR email = #{email}
    </select>

    <!-- 插入新用户 -->
    <insert id="registerUser" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO user (username, email, password_hash, role, phone, avatar_url)
        VALUES (#{username}, #{email}, #{passwordHash}, 'USER', #{phone}, #{avatarUrl})
    </insert>

    <!-- 查询用户通过用户名 -->
    <select id="findByUsername" resultType="org.example.strayanimalrescuebackend.model.User">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <!-- 查询邮箱是否已存在 -->
    <select id="findByEmail" resultType="org.example.strayanimalrescuebackend.model.User">
        SELECT * FROM user WHERE email = #{email}
    </select>

    <!-- 检查邮箱是否已存在（排除当前用户） -->
    <select id="checkEmailExists" resultType="int">
        SELECT COUNT(*) FROM user WHERE email = #{email} AND username != #{username}
    </select>

    <update id="updateUserProfile">
        UPDATE user
        SET email = #{email},
            phone = #{phone},
            avatar_url = #{avatarUrl}
        WHERE username = #{username}
    </update>

    <!-- 更新用户密码 -->
    <update id="updatePassword">
        UPDATE user
        SET password_hash = #{newPasswordHash}
        WHERE username = #{username}
    </update>


    <!-- 查询所有用户信息 -->
    <select id="findAllUsers" resultType="org.example.strayanimalrescuebackend.model.User">
        SELECT * FROM user
    </select>

    <!-- 根据用户 ID 查询用户 -->
    <select id="getUserById" parameterType="long" resultType="org.example.strayanimalrescuebackend.model.User">
        SELECT * FROM user WHERE user_id = #{id}
    </select>

<!--    更新用户角色-->
    <update id="updateUserRole" parameterType="map">
        UPDATE User
        SET role = #{role}
        WHERE user_id = #{userId}
    </update>

    <!-- 冻结或解冻用户账号 -->
    <update id="updateUserFrozenStatus">
        UPDATE User
        SET is_frozen = #{isFrozen}
        WHERE user_id = #{userId}
    </update>


</mapper>
